  const rX=`<?xml version="1.0" encoding="UTF-8" standalone="yes"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"><Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/styles" Target="styles.xml"/></Relationships>`;
  const sX=`<?xml version="1.0" encoding="UTF-8" standalone="yes"?><w:styles xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main"><w:docDefaults><w:rPrDefault><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr></w:rPrDefault></w:docDefaults><w:style w:type="paragraph" w:styleId="Normal"><w:name w:val="Normal"/><w:pPr><w:spacing w:after="120"/></w:pPr></w:style></w:styles>`;
  const cX=`<?xml version="1.0" encoding="UTF-8" standalone="yes"?><Types xmlns="http://schemas.openxmlformats.org/package/2006/content-types"><Default Extension="rels" ContentType="application/vnd.openxmlformats-package.relationships+xml"/><Default Extension="xml" ContentType="application/xml"/><Override PartName="/word/document.xml" ContentType="application/vnd.openxmlformats-officedocument.wordprocessingml.document.main+xml"/><Override PartName="/word/styles.xml" ContentType="application/vnd.openxmlformats-officedocument.wordprocessingml.styles+xml"/></Types>`;
  const rR=`<?xml version="1.0" encoding="UTF-8" standalone="yes"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"><Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument" Target="word/document.xml"/></Relationships>`;
  function buildZip(files){
    function crc32(d){
      const t=new Uint32Array(256);
      for(let n=0;n<256;n++){let c=n;for(let k=0;k<8;k++)c=c&1?(0xEDB88320^(c>>>1)):(c>>>1);t[n]=c;}
      let c=0xFFFFFFFF;
      for(let i=0;i<d.length;i++)c=(c>>>8)^t[(c^d[i])&0xFF];
      return(c^0xFFFFFFFF)>>>0;
    }
    const u16=n=>[(n)&0xFF,(n>>8)&0xFF];
    const u32=n=>[(n)&0xFF,(n>>8)&0xFF,(n>>16)&0xFF,(n>>24)&0xFF];
    const entries=[];
    for(const[nm,data]of files){
      const nb=new TextEncoder().encode(nm);
      const c=crc32(data);
      const sz=data.length;
      const lh=new Uint8Array([
        0x50,0x4B,0x03,0x04, // local file header sig
        0x14,0x00,           // version needed
        0x00,0x00,           // general purpose flag
        0x00,0x00,           // compression (stored)
        0x00,0x00,0x00,0x00, // mod time/date
        ...u32(c),           // crc32
        ...u32(sz),          // compressed size
        ...u32(sz),          // uncompressed size
        ...u16(nb.length),   // filename length
        0x00,0x00,           // extra field length
        ...nb
      ]);
      entries.push({nb,c,sz,lh,data});
    }
    // Build local headers + data
    const parts=[];
    let off=0;
    const cdEntries=[];
    for(const e of entries){
      cdEntries.push({...e,off});
      parts.push(e.lh,e.data);
      off+=e.lh.length+e.data.length;
    }
    // Central directory
    const cdParts=[];
    for(const e of cdEntries){
      const cd=new Uint8Array([
        0x50,0x4B,0x01,0x02, // central dir sig
        0x14,0x00,           // version made by
        0x14,0x00,           // version needed
        0x00,0x00,           // general purpose flag
        0x00,0x00,           // compression
        0x00,0x00,0x00,0x00, // mod time/date
        ...u32(e.c),
        ...u32(e.sz),
        ...u32(e.sz),
        ...u16(e.nb.length),
        0x00,0x00,           // extra field length
        0x00,0x00,           // file comment length
        0x00,0x00,           // disk number start
        0x00,0x00,           // internal attr
        0x00,0x00,0x00,0x00, // external attr
        ...u32(e.off),
        ...e.nb
      ]);
      cdParts.push(cd);
    }
    const cdSz=cdParts.reduce((a,b)=>a+b.length,0);
    const cdOff=off;
    const eocd=new Uint8Array([
      0x50,0x4B,0x05,0x06,
      0x00,0x00,0x00,0x00,
      ...u16(entries.length),
      ...u16(entries.length),
      ...u32(cdSz),
      ...u32(cdOff),
      0x00,0x00
    ]);
    const all=[...parts,...cdParts,eocd];
    const tot=all.reduce((a,b)=>a+b.length,0);
    const out=new Uint8Array(tot);
    let p=0;for(const chunk of all){out.set(chunk,p);p+=chunk.length;}
    return out;
  }
  const z=buildZip([["[Content_Types].xml",E(cX)],["_rels/.rels",E(rR)],["word/document.xml",E(doc)],["word/styles.xml",E(sX)],["word/_rels/document.xml.rels",E(rX)]]);
  return new Blob([z],{type:"application/vnd.openxmlformats-officedocument.wordprocessingml.document"});
}

export default function App(){
  const[educator,setEducator]=useState("");
  const[supervisor,setSupervisor]=useState("");
  const[school,setSchool]=useState("");
  const[circuit,setCircuit]=useState("");
  const[district,setDistrict]=useState("");
  const[subject,setSubject]=useState("");
  const[grade,setGrade]=useState("");
  const[term,setTerm]=useState("Term 1");
  const[classes,setClasses]=useState([]);
  const[classInput,setClassInput]=useState("");
  const[files,setFiles]=useState([]);
  const[dragOver,setDragOver]=useState(false);
  const[readStatus,setReadStatus]=useState("");
  const[sending,setSending]=useState(false);
  const[waiting,setWaiting]=useState(false);
  const[analysis,setAnalysis]=useState(null);
  const[diagnostics,setDiagnostics]=useState("");
  const[errMsg,setErrMsg]=useState("");
  const[promptText,setPromptText]=useState("");
  const[analyzing,setAnalyzing]=useState(false);
  const fileRef=useRef();

  useEffect(()=>{
    const load=src=>new Promise(r=>{if(document.querySelector(`script[src="${src}"]`)){r();return;}const s=document.createElement("script");s.src=src;s.onload=r;document.head.appendChild(s);});
    load("https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js");
    load("https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js").then(()=>{if(window.pdfjsLib)window.pdfjsLib.GlobalWorkerOptions.workerSrc="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";});
  },[]);

  useEffect(()=>{
    (async()=>{try{const s=await window.storage.get("qwz-form");if(!s)return;const d=JSON.parse(s.value);
      if(d.educator)setEducator(d.educator);
      if(d.supervisor)setSupervisor(d.supervisor);
      if(d.school)setSchool(d.school);
      if(d.circuit)setCircuit(d.circuit);
      if(d.district)setDistrict(d.district);
      if(d.subject)setSubject(d.subject);
      if(d.grade)setGrade(d.grade);
      if(d.term)setTerm(d.term);
      if(d.classes)setClasses(d.classes);
    }catch{}})();
  },[]);

  const save=async p=>{try{await window.storage.set("qwz-form",JSON.stringify({educator,supervisor,school,circuit,district,subject,grade,term,classes,...p}));}catch{}};

  const addClass=()=>{const v=classInput.trim().toUpperCase();if(v&&!classes.includes(v)){const n=[...classes,v];setClasses(n);save({classes:n});}setClassInput("");};
  const removeC=c=>{const n=classes.filter(x=>x!==c);setClasses(n);save({classes:n});};

  const addFiles=raw=>setFiles(prev=>{
    const next=[...prev];
    for(const f of raw){if(next.find(x=>x.file.name===f.name))continue;const ext=f.name.split(".").pop().toLowerCase();const isImg=IMG_EXTS.has(ext)||(f.type||"").startsWith("image/");const isPdf=ext==="pdf";next.push({file:f,isImg,isPdf,previewUrl:isImg?URL.createObjectURL(f):null});}
    return next;
  });
  const removeFile=i=>setFiles(prev=>{if(prev[i].previewUrl)URL.revokeObjectURL(prev[i].previewUrl);return prev.filter((_,j)=>j!==i);});

  const sendToClaude=async()=>{
    if(!educator||!subject||!grade){setErrMsg("Please fill in Educator name, Subject and Grade.");return;}
    if(!files.length){setErrMsg("Please upload at least one file.");return;}
    setErrMsg("");setSending(true);
    try{
      const chunks=[];
      for(let i=0;i<files.length;i++){setReadStatus(`Reading ${i+1}/${files.length}: ${files[i].file.name}…`);chunks.push(await extractFileText(files[i].file,files[i].isImg,files[i].isPdf));}
      setReadStatus("");
      const allText=chunks.join("\n\n").substring(0,28000);
      const nextTerm=term==="Term 4"?"Term 1 (next year)":`Term ${parseInt(term.split(" ")[1])+1}`;
      const userPrompt=`ANALYSE THESE MARK SHEETS and respond with ONLY a JSON object (no prose, no markdown fences).

CONTEXT: Subject: ${subject}, Grade: ${grade}, ${term}, Educator: ${educator}, School: ${school||"Not specified"}

FILE DATA:
${allText}

Required JSON format:
{
  "classes": [
    {
      "className": "7A",
      "learners": [{"name":"SURNAME, Firstname","totalPct":72.5}]
    }
  ],
  "diagnostics": "DIAGNOSTIC SUMMARY\\n[3-4 sentences on overall performance]\\n\\nKEY CHALLENGE AREAS\\n- Task: challenge description with learner count\\n- Task: challenge description\\n\\nRECOMMENDED INTERVENTIONS\\n- Task: CAPS-aligned strategy\\n- Task: strategy\\n\\nGENERAL COMMENTS FOR HOD\\n[2-3 sentences for ${nextTerm} targets]"
}

Rules:
- totalPct = each learner's overall percentage (0-100), rounded to 1 decimal
- Calculate from task marks: sum(marks)/sum(maxMarks)×100
- Assign the class average to any learner with no mark recorded (do not exclude them)
- Use -1 only for officially absent learners (marked as absent in the source data)
- Detect class names from file names or data headers
- For image files: read the mark sheet exactly as visible in the image
- diagnostics must be a single escaped string with \\n for newlines
- Reference actual numbers and percentages in diagnostics`;
      setSending(false);
      setAnalyzing(true);
      const res=await fetch("https://api.anthropic.com/v1/messages",{
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:8000,messages:[{role:"user",content:userPrompt}]})
      });
      if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(`API error ${res.status}: ${e?.error?.message||"unknown"}`);}
      const d=await res.json();
      const raw=d.content.filter(b=>b.type==="text").map(b=>b.text).join("");
      processResponse(raw);
    }catch(e){
      setErrMsg("Analysis failed: "+e.message);
      setSending(false);
      setAnalyzing(false);
    }
  };

  const processResponse=(raw)=>{
    try{
      const data=JSON.parse(raw.replace(/^```(?:json)?\s*/i,"").replace(/\s*```\s*$/i,"").trim());
      const computed=data.classes.map(cls=>{
        const marks=cls.learners.map(l=>l.totalPct).filter(m=>m>=0);
        const n=marks.length,passed=marks.filter(m=>m>=50).length,failed=n-passed;
        const avg=n?+(marks.reduce((a,b)=>a+b,0)/n).toFixed(1):0;
        const passRate=n?+(passed/n*100).toFixed(1):0;
        const levels=[1,2,3,4,5,6,7].map(l=>marks.filter(m=>getLevel(m)===l).length);
        return{className:cls.className,n,passed,failed,avg,passRate,levels};
      });
      const tN=computed.reduce((a,c)=>a+c.n,0),tP=computed.reduce((a,c)=>a+c.passed,0),tF=computed.reduce((a,c)=>a+c.failed,0);
      const cA=tN?+(computed.reduce((a,c)=>a+c.avg*c.n,0)/tN).toFixed(1):0;
      const cP=tN?+(tP/tN*100).toFixed(1):0;
      const cL=[0,1,2,3,4,5,6].map(i=>computed.reduce((a,c)=>a+c.levels[i],0));
      const result={computed,totalN:tN,totalPassed:tP,totalFailed:tF,combinedAvg:cA,combinedPassRate:cP,combinedLevels:cL};
      const diag=(data.diagnostics||"").replace(/\\n/g,"\n");
      setAnalysis(result);setDiagnostics(diag);setAnalyzing(false);setWaiting(false);
      try{window.storage.set("qwz-last",JSON.stringify({analysis:result,diagnostics:diag,meta:{educator,supervisor,school,circuit,district,subject,grade,term,year:new Date().getFullYear()}}));}catch{}
    }catch(e){setErrMsg("Could not parse response: "+e.message);setAnalyzing(false);}
  };

  const downloadDocx=()=>{
    try{
      const blob=buildDocxBlob(analysis,diagnostics,{educator,supervisor,school,circuit,district,subject,grade,term,year:new Date().getFullYear()});
      const url=URL.createObjectURL(blob);const a=document.createElement("a");a.href=url;
      a.download=`Analysis_SIP_${subject.replace(/\s+/g,"_")}_Gr${grade}_${term.replace(/\s+/g,"")}_${new Date().getFullYear()}.docx`;
      document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);
    }catch(e){setErrMsg("Download failed: "+e.message);}
  };

  const reset=()=>{files.forEach(f=>{if(f.previewUrl)URL.revokeObjectURL(f.previewUrl);});setFiles([]);setAnalysis(null);setDiagnostics("");setWaiting(false);setAnalyzing(false);setPromptText("");setErrMsg("");setReadStatus("");};
  const maxV=analysis?Math.max(...analysis.combinedLevels,1):1;
  const fi=f=>f.isImg?"🖼":f.isPdf?"📕":"📊";

  return(<>
    <style>{CSS}</style>
    <div className="shell">
      <div className="qw-head">
        <div className="qw-logo">Qw</div>
        <div>
          <div className="qw-title">Qwerzy Mark Analysis Tool</div>
          <div className="qw-sub">We Play To Learn — {school||"Enter your school name"}</div>
        </div>
        <div className="qw-badge">SASAMS Aligned</div>
      </div>
      <div className="how-box">
        <div className="how-title">How to use</div>
        <div className="how-step"><div className="how-num">1</div><div>Fill in your details and upload mark sheets (spreadsheets, PDFs or photos of mark sheets)</div></div>
        <div className="how-step"><div className="how-num">2</div><div>Click <strong>Send to Claude for analysis</strong> — the prompt is prepared and copied to your clipboard</div></div>
        <div className="how-step"><div className="how-num">3</div><div>Paste the prompt into a new Claude chat, wait for the JSON reply, then click <strong>Load Claude's response</strong> and paste it in to download your .docx report</div></div>
      </div>
      <div className="step-label">Step 1 — Educator details</div>
      <div className="card">
        <div className="card-title">Enter your information</div>
        <div className="row2">
          <div><label className="lbl">Educator name</label><input value={educator} onChange={e=>{setEducator(e.target.value);save({educator:e.target.value});}} placeholder="e.g. Ms N. Sokhulu"/></div>
          <div><label className="lbl">HOD / Supervisor</label><input value={supervisor} onChange={e=>{setSupervisor(e.target.value);save({supervisor:e.target.value});}} placeholder="e.g. Mr T. Dlamini"/></div>
        </div>
        <div className="row3">
          <div><label className="lbl">School name</label><input value={school} onChange={e=>{setSchool(e.target.value);save({school:e.target.value});}} placeholder="e.g. Briardene Primary"/></div>
          <div><label className="lbl">Circuit</label><input value={circuit} onChange={e=>{setCircuit(e.target.value);save({circuit:e.target.value});}} placeholder="e.g. Durban Central"/></div>
          <div><label className="lbl">District</label><input value={district} onChange={e=>{setDistrict(e.target.value);save({district:e.target.value});}} placeholder="e.g. eThekwini"/></div>
        </div>
        <div className="row3">
          <div><label className="lbl">Subject</label><input value={subject} onChange={e=>{setSubject(e.target.value);save({subject:e.target.value});}} placeholder="e.g. IsiZulu FAL"/></div>
          <div><label className="lbl">Grade</label><input value={grade} onChange={e=>{setGrade(e.target.value);save({grade:e.target.value});}} placeholder="e.g. 7"/></div>
          <div><label className="lbl">Term</label>
            <select value={term} onChange={e=>{setTerm(e.target.value);save({term:e.target.value});}}>
              {["Term 1","Term 2","Term 3","Term 4"].map(t=><option key={t}>{t}</option>)}
            </select>
          </div>
        </div>
        <label className="lbl">Classes <span style={{fontWeight:400,textTransform:"none",letterSpacing:0}}>(optional — auto-detected if blank)</span></label>
        <div className="tags">{classes.map(c=><span key={c} className="tag">{c}<button onClick={()=>removeC(c)}>×</button></span>)}</div>
        <div className="add-row">
          <input value={classInput} onChange={e=>setClassInput(e.target.value.toUpperCase())} onKeyDown={e=>{if(e.key==="Enter"){e.preventDefault();addClass();}}} placeholder="e.g. 7A" maxLength={10}/>
          <button className="btn-sm" onClick={addClass}>+ Add</button>
        </div>
      </div>
      <div className="step-label">Step 2 — Upload mark sheets</div>
      <div className="card">
        <div className="card-title">Upload files <span style={{fontSize:".72rem",fontWeight:400,color:"#5a7a9d"}}>XLS · XLSX · CSV · TXT · PDF · JPG · PNG</span></div>
        <div className={`drop${dragOver?" over":""}`} onClick={()=>fileRef.current.click()} onDragOver={e=>{e.preventDefault();setDragOver(true);}} onDragLeave={()=>setDragOver(false)} onDrop={e=>{e.preventDefault();setDragOver(false);addFiles(e.dataTransfer.files);}}>
          <div style={{fontSize:"1.6rem",marginBottom:".3rem"}}>📂</div>
          <div style={{fontSize:".875rem",color:"#3d5a80"}}>Drop files here or click to browse</div>
          <div style={{fontSize:".7rem",color:"#5a7a9d",marginTop:3}}>Spreadsheets, PDFs and images all accepted</div>
          <input ref={fileRef} type="file" multiple accept={ACCEPT} style={{display:"none"}} onChange={e=>addFiles(e.target.files)}/>
        </div>
        {files.map((f,i)=>(
          <div key={i} className="file-item">
            {f.previewUrl?<img className="file-thumb" src={f.previewUrl} alt=""/>:<span style={{fontSize:"1.1rem",flexShrink:0}}>{fi(f)}</span>}
            <span className="file-name">{f.file.name}</span>
            <span className="file-meta">{fi(f)} {f.isImg?"image":f.isPdf?"pdf":"sheet"} · {(f.file.size/1024).toFixed(0)} KB</span>
            <button className="btn-sm" onClick={()=>removeFile(i)}>Remove</button>
          </div>
        ))}
        {readStatus&&<div className="read-status">{readStatus}</div>}
      </div>
      <div className="step-label">Step 3 — Analyse</div>
      <div className="action-row">
        <button className="btn-main orange" disabled={sending||analyzing} onClick={sendToClaude}>
          {sending?<><div className="spinner"/>Reading files…</>:analyzing?<><div className="spinner"/>Analysing…</>:"Send to Claude for analysis"}
        </button>
        {(analyzing||analysis)&&<button className="btn-sm" onClick={reset}>Start over</button>}
      </div>
      {errMsg&&<div className="err-box"><strong>Error:</strong> {errMsg}</div>}
      {analyzing&&(
        <div className="waiting">
          <p className="pulse">🔍 Analysing mark sheets… please wait</p>
          <small>This may take 20–40 seconds depending on file size</small>
        </div>
      )}
      {analysis&&(
        <>
          <div className="step-label" style={{background:"#16a34a"}}>Results</div>
          <div className="card">
            <div className="card-title">Analysis summary</div>
            <div className="stats-grid">
              {[{n:analysis.totalN,l:"Learners wrote",c:"#004E89"},{n:analysis.totalPassed,l:"Passed (≥50%)",c:"#16a34a"},{n:analysis.totalFailed,l:"Failed",c:"#dc2626"},{n:analysis.combinedAvg+"%",l:"Average mark",c:"#FF6B35"}].map((s,i)=>(
                <div key={i} className="stat-box"><div className="stat-num" style={{color:s.c}}>{s.n}</div><div className="stat-lbl">{s.l}</div></div>
              ))}
            </div>
            <div className="sec-title">Overall level distribution</div>
            <div className="lvl-bars">
              {analysis.combinedLevels.map((v,i)=>(
                <div key={i} className="lvl-col">
                  <div className="lvl-val">{v}</div>
                  <div className="lvl-bar" style={{height:Math.round(v/maxV*52)+"px",background:LCOLS[i]}}/>
                  <div className="lvl-lbl">L{i+1}</div>
                </div>
              ))}
            </div>
            <div className="card-title" style={{marginTop:".875rem"}}>Per-class breakdown</div>
            <table className="cls-table">
              <thead><tr><th>Class</th><th>Wrote</th><th>Passed</th><th>Failed</th><th>Pass rate</th><th>Average</th></tr></thead>
              <tbody>
                {analysis.computed.map((c,i)=>(
                  <tr key={i}><td><strong>{c.className}</strong></td><td>{c.n}</td><td>{c.passed}</td><td>{c.failed}</td><td><span className={`badge ${bc(c.passRate)}`}>{c.passRate}%</span></td><td>{c.avg}%</td></tr>
                ))}
                {analysis.computed.length>1&&(
                  <tr><td>Combined</td><td>{analysis.totalN}</td><td>{analysis.totalPassed}</td><td>{analysis.totalFailed}</td><td><span className={`badge ${bc(analysis.combinedPassRate)}`}>{analysis.combinedPassRate}%</span></td><td>{analysis.combinedAvg}%</td></tr>
                )}
              </tbody>
            </table>
            {diagnostics&&(<><div className="card-title">Diagnostic commentary</div><div className="diag-box">{diagnostics}</div></>)}
            <div className="action-row">
              <button className="btn-main green" onClick={downloadDocx}>↓ Download .docx report</button>

              <button className="btn-sm" onClick={reset}>Start over</button>
            </div>
          </div>
        </>
      )}
    </div>
  </>);
}
