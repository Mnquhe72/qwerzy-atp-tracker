const readBuf  = f=>new Promise((r,j)=>{const x=new FileReader();x.onload=e=>r(e.target.result);x.onerror=j;x.readAsArrayBuffer(f);});
const readText = f=>new Promise((r,j)=>{const x=new FileReader();x.onload=e=>r(e.target.result);x.onerror=j;x.readAsText(f);});

async function extractFileText(file,isImg,isPdf){
  const ext=file.name.split(".").pop().toLowerCase();
  if(isImg) return `[IMAGE FILE: ${file.name} — extract all marks visible in this image]`;
  if(isPdf){
    try{
      const buf=await readBuf(file);
      const pdf=await window.pdfjsLib.getDocument({data:buf}).promise;
      let text="";
      for(let p=1;p<=Math.min(pdf.numPages,20);p++){const pg=await pdf.getPage(p);const ct=await pg.getTextContent();text+=ct.items.map(i=>i.str).join(" ")+"\n";}
      return `=== PDF: ${file.name} ===\n${text.substring(0,14000)}`;
    }catch(e){return `=== PDF: ${file.name} (error: ${e.message}) ===`;}
  }
  if((ext==="xls"||ext==="xlsx")&&window.XLSX){
    const buf=await readBuf(file);const wb=window.XLSX.read(buf,{type:"array"});
    let out="";wb.SheetNames.forEach(sn=>{out+=`\n[Sheet: ${sn}]\n`+window.XLSX.utils.sheet_to_csv(wb.Sheets[sn]);});
    return `=== SPREADSHEET: ${file.name} ===\n${out.substring(0,14000)}`;
  }
  return `=== FILE: ${file.name} ===\n${(await readText(file)).substring(0,14000)}`;
}

