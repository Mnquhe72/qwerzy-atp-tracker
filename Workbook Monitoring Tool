<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Workbook Monitoring Tool</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/docx/8.5.0/docx.umd.min.js"></script>
  <style>
    :root {
      --primary: #1a2a4a;
      --accent: #2e7d32;
      --accent-light: #e8f5e9;
      --red: #c0392b;
      --blue: #1565c0;
      --border: #bdbdbd;
      --bg: #f0f2f5;
      --white: #fff;
      --text: #212121;
      --muted: #666;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: var(--bg); color: var(--text); padding: 24px 16px 60px; }

    .toolbar { max-width: 860px; margin: 0 auto 16px; display: flex; gap: 10px; flex-wrap: wrap; }
    .toolbar button {
      display: flex; align-items: center; gap: 7px;
      padding: 9px 18px; border: none; border-radius: 6px;
      font-size: 14px; font-weight: 600; cursor: pointer; color: var(--white);
      transition: opacity .2s, transform .1s;
    }
    .toolbar button:hover { opacity: .88; }
    .toolbar button:active { transform: scale(.97); }
    .btn-print { background: var(--primary); }
    .btn-pdf   { background: var(--red); }
    .btn-word  { background: var(--blue); }
    .btn-reset { background: #757575; margin-left: auto; }

    .card { max-width: 860px; margin: 0 auto; background: var(--white); border-radius: 10px; box-shadow: 0 2px 16px rgba(0,0,0,.10); overflow: hidden; }

    .report-header { background: var(--primary); color: var(--white); padding: 22px 32px 18px; }
    .header-inner { display: flex; align-items: center; gap: 24px; }

    /* Logo area */
    .logo-area { cursor: pointer; flex-shrink: 0; }
    .logo-placeholder {
      width: 90px; height: 90px; border: 2px dashed rgba(255,255,255,.45);
      border-radius: 8px; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 5px;
      transition: border-color .2s, background .2s;
    }
    .logo-area:hover .logo-placeholder { border-color: rgba(255,255,255,.9); background: rgba(255,255,255,.08); }
    .logo-icon { font-size: 26px; }
    .logo-hint { font-size: 10px; opacity: .7; text-align: center; line-height: 1.3; }
    #logo-preview { width: 90px; height: 90px; object-fit: contain; border-radius: 6px; }

    /* Header text */
    .header-text { flex: 1; }
    .report-header .report-title { font-size: 20px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; }
    .report-header .report-subtitle { font-size: 13px; font-weight: 400; margin-top: 5px; opacity: .75; letter-spacing: 1px; text-transform: uppercase; }
    .header-rule { border: none; border-top: 2px solid rgba(255,255,255,.3); margin: 14px 0 0; }

    .report-body { padding: 28px 32px; }

    .section-title {
      font-size: 11px; font-weight: 700; letter-spacing: 1.8px; text-transform: uppercase;
      color: var(--white); background: var(--primary); padding: 7px 12px; border-radius: 4px; margin: 26px 0 14px;
    }

    .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .meta-grid .field-group.full { grid-column: 1 / -1; }

    .field-group label { display: block; font-size: 11px; font-weight: 600; letter-spacing: .8px; text-transform: uppercase; color: var(--muted); margin-bottom: 5px; }
    .field-group input[type="text"],
    .field-group input[type="date"],
    .field-group textarea {
      width: 100%; border: 1.5px solid var(--border); border-radius: 6px;
      padding: 9px 11px; font-size: 14px; font-family: inherit; color: var(--text);
      background: #fafafa; transition: border-color .2s; outline: none;
    }
    .field-group input:focus, .field-group textarea:focus { border-color: var(--accent); background: var(--white); }
    .field-group textarea { resize: vertical; min-height: 64px; }

    .eval-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .eval-table thead tr { background: var(--primary); color: var(--white); }
    .eval-table thead th { padding: 10px 12px; font-weight: 600; font-size: 12px; letter-spacing: .5px; text-align: left; }
    .eval-table th:nth-child(1) { width: 42px; text-align: center; }
    .eval-table th:nth-child(3) { width: 110px; text-align: center; }
    .eval-table tbody tr { border-bottom: 1px solid #e0e0e0; }
    .eval-table tbody tr:nth-child(even) { background: #fafafa; }
    .eval-table tbody td { padding: 10px 12px; vertical-align: middle; }
    .eval-table tbody td:nth-child(1) { text-align: center; font-weight: 600; color: var(--muted); }
    .eval-table tbody td:nth-child(3) { text-align: center; }

    .eval-table input[type="checkbox"] {
      appearance: none; -webkit-appearance: none;
      width: 22px; height: 22px; border: 2px solid var(--border); border-radius: 5px;
      cursor: pointer; position: relative; transition: background .15s, border-color .15s; vertical-align: middle;
    }
    .eval-table input[type="checkbox"]:checked { background: var(--accent); border-color: var(--accent); }
    .eval-table input[type="checkbox"]:checked::after {
      content: '✓'; position: absolute; top: -1px; left: 3px;
      font-size: 15px; color: white; font-weight: 700;
    }
    .eval-table input[type="text"] {
      width: 100%; border: 1.5px solid var(--border); border-radius: 5px;
      padding: 7px 9px; font-size: 13px; font-family: inherit; background: #fafafa; outline: none; transition: border-color .2s;
    }
    .eval-table input[type="text"]:focus { border-color: var(--accent); background: var(--white); }

    .rating-row { display: flex; align-items: center; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
    .rating-row label { font-size: 13px; font-weight: 600; color: var(--muted); }
    .rating-btn {
      padding: 6px 16px; border: 2px solid var(--border); border-radius: 20px;
      background: var(--white); font-size: 13px; font-weight: 600; cursor: pointer;
      transition: all .2s; color: var(--text);
    }
    .rating-btn:hover { border-color: var(--accent); color: var(--accent); }
    .rating-btn.active { background: var(--accent); border-color: var(--accent); color: white; }
    .rating-btn.active.warn { background: #f57c00; border-color: #f57c00; }
    .rating-btn.active.danger { background: var(--red); border-color: var(--red); }

    .sig-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 28px; }
    .sig-box { border: 1.5px solid var(--border); border-radius: 8px; padding: 16px 18px 14px; }
    .sig-box strong { font-size: 13px; }
    .sig-box input[type="text"] {
      width: 100%; border: none; border-bottom: 1.5px solid var(--border);
      padding: 6px 2px; font-size: 14px; font-family: inherit; outline: none; margin-top: 10px; background: transparent;
    }
    .sig-space { height: 52px; }
    .sig-label { text-align: center; font-size: 11px; color: var(--muted); border-top: 1.5px solid var(--border); padding-top: 6px; margin-top: 4px; }

    /* Toast */
    #toast {
      position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(20px);
      background: #323232; color: white; padding: 12px 24px; border-radius: 8px;
      font-size: 14px; opacity: 0; transition: opacity .3s, transform .3s; pointer-events: none; z-index: 999;
    }
    #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    @media print {
      body { background: white; padding: 0; }
      .toolbar { display: none; }
      .card { box-shadow: none; border-radius: 0; }
      .report-header, .section-title, .eval-table thead tr { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      input, textarea { border: none !important; background: transparent !important; }
      .rating-btn:not(.active) { display: none; }
    }
  </style>
</head>
<body>

<div class="toolbar">
  <button class="btn-print" onclick="window.print()">🖨️ Print</button>
  <button class="btn-pdf"   onclick="window.print()">📄 Save as PDF</button>
  <button class="btn-word"  onclick="saveAsDocx()">📝 Export to Word (.docx)</button>
  <button class="btn-reset" onclick="resetForm()">↺ Clear Form</button>
</div>

<div class="card" id="report-content">
  <div class="report-header">
    <div class="header-inner">
      <label class="logo-area" id="logo-label" title="Click to upload school logo">
        <input type="file" id="logo-upload" accept="image/*" style="display:none;">
        <div class="logo-placeholder" id="logo-placeholder">
          <span class="logo-icon">🏫</span>
          <span class="logo-hint">Click to add logo</span>
        </div>
        <img id="logo-preview" src="" alt="School Logo" style="display:none;">
      </label>
      <div class="header-text">
        <div class="report-title">Workbook Monitoring Tool</div>
        <div class="report-subtitle">Workbook Supervision Report</div>
      </div>
    </div>
    <hr class="header-rule">
  </div>

  <div class="report-body">
    <div class="section-title">Report Details</div>
    <div class="meta-grid">
      <div class="field-group">
        <label>Date</label>
        <input type="date" id="date">
      </div>
      <div class="field-group">
        <label>Educator</label>
        <input type="text" id="educator" placeholder="Full name">
      </div>
      <div class="field-group">
        <label>Subject</label>
        <input type="text" id="subject" placeholder="e.g. Mathematics">
      </div>
      <div class="field-group">
        <label>Grade / Class</label>
        <input type="text" id="grade" placeholder="e.g. Grade 5A">
      </div>
      <div class="field-group">
        <label>Class Roll</label>
        <input type="text" id="roll" placeholder="e.g. 32">
      </div>
      <div class="field-group">
        <label>Books Submitted</label>
        <input type="text" id="books" placeholder="e.g. 30">
      </div>
      <div class="field-group full">
        <label>Learners Not Submitting (names / reason)</label>
        <textarea id="learners" placeholder="List any learners who did not submit and the reason where known…"></textarea>
      </div>
    </div>

    <div class="section-title">Areas of Evaluation</div>
    <table class="eval-table" id="evaluationTable">
      <thead>
        <tr><th>#</th><th>Area</th><th>Evident</th><th>Remarks</th></tr>
      </thead>
      <tbody>
        <tr><td>1</td><td>Interesting variety of exercises</td><td><input type="checkbox" class="eval-check"></td><td><input type="text" class="eval-remark" placeholder="Optional remark…"></td></tr>
        <tr><td>2</td><td>Remedial work done</td><td><input type="checkbox" class="eval-check"></td><td><input type="text" class="eval-remark" placeholder="Optional remark…"></td></tr>
        <tr><td>3</td><td>Curriculum coverage</td><td><input type="checkbox" class="eval-check"></td><td><input type="text" class="eval-remark" placeholder="Optional remark…"></td></tr>
        <tr><td>4</td><td>Comments to motivate and inspire learners</td><td><input type="checkbox" class="eval-check"></td><td><input type="text" class="eval-remark" placeholder="Optional remark…"></td></tr>
        <tr><td>5</td><td>Marking is up to date</td><td><input type="checkbox" class="eval-check"></td><td><input type="text" class="eval-remark" placeholder="Optional remark…"></td></tr>
        <tr><td>6</td><td>Corrections done by learners</td><td><input type="checkbox" class="eval-check"></td><td><input type="text" class="eval-remark" placeholder="Optional remark…"></td></tr>
        <tr><td>7</td><td>Date and headings present</td><td><input type="checkbox" class="eval-check"></td><td><input type="text" class="eval-remark" placeholder="Optional remark…"></td></tr>
      </tbody>
    </table>

    <div class="rating-row">
      <label>Overall Rating:</label>
      <button class="rating-btn" data-val="Outstanding" onclick="setRating(this)">Outstanding</button>
      <button class="rating-btn" data-val="Good" onclick="setRating(this)">Good</button>
      <button class="rating-btn warn" data-val="Satisfactory" onclick="setRating(this)">Satisfactory</button>
      <button class="rating-btn danger" data-val="Needs Improvement" onclick="setRating(this)">Needs Improvement</button>
    </div>

    <div class="section-title" style="margin-top:26px;">General Remarks</div>
    <div class="field-group">
      <textarea id="general" rows="5" placeholder="Provide overall feedback, commendations, and areas for development…"></textarea>
    </div>

    <div class="section-title">Follow-Up Actions</div>
    <div class="field-group">
      <textarea id="followup" rows="3" placeholder="Specify any actions required by the educator and the deadline…"></textarea>
    </div>

    <div class="section-title">Acknowledgement</div>
    <div class="sig-row">
      <div class="sig-box">
        <strong>Supervisor / HOD</strong>
        <input type="text" id="supervisor-name" placeholder="Full name">
        <div class="sig-space"></div>
        <div class="sig-label">Signature &amp; Date</div>
      </div>
      <div class="sig-box">
        <strong>Educator</strong>
        <div class="sig-space" style="height:42px;"></div>
        <div class="sig-label">Signature &amp; Date</div>
      </div>
    </div>
  </div>
</div>

<div id="toast">✅ Downloading your .docx file…</div>

<script>
  document.getElementById('date').valueAsDate = new Date();

  // Logo upload preview
  document.getElementById('logo-upload').addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      const preview = document.getElementById('logo-preview');
      const placeholder = document.getElementById('logo-placeholder');
      preview.src = e.target.result;
      preview.style.display = 'block';
      placeholder.style.display = 'none';
    };
    reader.readAsDataURL(file);
  });

  let selectedRating = '';
  function setRating(btn) {
    document.querySelectorAll('.rating-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    selectedRating = btn.dataset.val;
  }

  function resetForm() {
    if (!confirm('Clear all fields and start a new report?')) return;
    document.querySelectorAll('input[type="text"], textarea').forEach(el => el.value = '');
    document.querySelectorAll('input[type="checkbox"]').forEach(el => el.checked = false);
    document.querySelectorAll('.rating-btn').forEach(b => b.classList.remove('active'));
    selectedRating = '';
    document.getElementById('date').valueAsDate = new Date();
  }

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  async function saveAsDocx() {
    const { Document, Packer, Paragraph, Table, TableRow, TableCell,
            TextRun, HeadingLevel, AlignmentType, WidthType,
            BorderStyle, ShadingType, VerticalAlign } = docx;

    // ── Colours ──
    const NAVY   = "1A2A4A";
    const WHITE  = "FFFFFF";
    const LGRAY  = "F2F2F2";
    const BLACK  = "000000";

    // ── Helper: shaded header cell ──
    function hdrCell(text, widthPct) {
      return new TableCell({
        width: { size: widthPct, type: WidthType.PERCENTAGE },
        shading: { type: ShadingType.SOLID, color: NAVY, fill: NAVY },
        verticalAlign: VerticalAlign.CENTER,
        children: [new Paragraph({
          alignment: AlignmentType.CENTER,
          children: [new TextRun({ text, bold: true, color: WHITE, size: 20 })]
        })]
      });
    }

    // ── Helper: plain cell ──
    function cell(text, widthPct, opts = {}) {
      return new TableCell({
        width: { size: widthPct, type: WidthType.PERCENTAGE },
        shading: opts.shade ? { type: ShadingType.SOLID, color: LGRAY, fill: LGRAY } : undefined,
        verticalAlign: VerticalAlign.CENTER,
        children: [new Paragraph({
          alignment: opts.center ? AlignmentType.CENTER : AlignmentType.LEFT,
          children: [new TextRun({ text: text || '—', size: 20, bold: opts.bold || false })]
        })]
      });
    }

    // ── Helper: label + value row ──
    function metaRow(label, value) {
      return new TableRow({ children: [
        cell(label, 25, { shade: true, bold: true }),
        cell(value,  75)
      ]});
    }

    // ── Section heading paragraph ──
    function sectionHeading(text) {
      return new Paragraph({
        spacing: { before: 240, after: 100 },
        shading: { type: ShadingType.SOLID, color: NAVY, fill: NAVY },
        children: [new TextRun({ text: text.toUpperCase(), bold: true, color: WHITE, size: 20, allCaps: true })]
      });
    }

    // ── Gather field values ──
    const v = id => document.getElementById(id).value || '—';

    // ── Eval table rows ──
    const evalRows = [];
    document.querySelectorAll('#evaluationTable tbody tr').forEach((row, i) => {
      const area    = row.cells[1].textContent.trim();
      const evident = row.querySelector('.eval-check').checked ? '✔  Yes' : '✘  No';
      const remark  = row.querySelector('.eval-remark').value || '—';
      evalRows.push(new TableRow({
        children: [
          cell(String(i + 1), 8,  { center: true }),
          cell(area,          45),
          cell(evident,       17, { center: true }),
          cell(remark,        30)
        ]
      }));
    });

    // ── Build document ──
    const doc = new Document({
      styles: {
        default: {
          document: { run: { font: "Calibri", size: 22 } }
        }
      },
      sections: [{
        properties: {
          page: { margin: { top: 720, bottom: 720, left: 900, right: 900 } }
        },
        children: [

          // Title block
          new Paragraph({
            alignment: AlignmentType.CENTER,
            spacing: { after: 60 },
            children: [new TextRun({ text: "BRIARDENE PRIMARY SCHOOL", bold: true, size: 32, color: NAVY, allCaps: true })]
          }),
          new Paragraph({
            alignment: AlignmentType.CENTER,
            spacing: { after: 280 },
            children: [new TextRun({ text: "Workbook Monitoring Tool", size: 24, color: "444444" })]
          }),

          // ── Report Details ──
          sectionHeading("Report Details"),
          new Table({
            width: { size: 100, type: WidthType.PERCENTAGE },
            rows: [
              metaRow("Date",            v('date')),
              metaRow("Educator",        v('educator')),
              metaRow("Subject",         v('subject')),
              metaRow("Grade / Class",   v('grade')),
              metaRow("Class Roll",      v('roll')),
              metaRow("Books Submitted", v('books')),
              metaRow("Learners Not Submitting", v('learners')),
            ]
          }),

          // ── Areas of Evaluation ──
          sectionHeading("Areas of Evaluation"),
          new Table({
            width: { size: 100, type: WidthType.PERCENTAGE },
            rows: [
              new TableRow({ tableHeader: true, children: [
                hdrCell("#",       8),
                hdrCell("Area",   45),
                hdrCell("Evident",17),
                hdrCell("Remarks",30),
              ]}),
              ...evalRows
            ]
          }),

          // Overall Rating
          new Paragraph({
            spacing: { before: 200, after: 60 },
            children: [
              new TextRun({ text: "Overall Rating:  ", bold: true, size: 22 }),
              new TextRun({ text: selectedRating || "—", size: 22 })
            ]
          }),

          // ── General Remarks ──
          sectionHeading("General Remarks"),
          new Paragraph({ spacing: { after: 60 }, children: [new TextRun({ text: v('general'), size: 22 })] }),

          // ── Follow-Up Actions ──
          sectionHeading("Follow-Up Actions"),
          new Paragraph({ spacing: { after: 60 }, children: [new TextRun({ text: v('followup'), size: 22 })] }),

          // ── Acknowledgement ──
          sectionHeading("Acknowledgement"),
          new Table({
            width: { size: 100, type: WidthType.PERCENTAGE },
            rows: [
              new TableRow({ children: [
                new TableCell({
                  width: { size: 50, type: WidthType.PERCENTAGE },
                  children: [
                    new Paragraph({ children: [new TextRun({ text: "Supervisor / HOD:", bold: true, size: 22 })] }),
                    new Paragraph({ children: [new TextRun({ text: v('supervisor-name'), size: 22 })] }),
                    new Paragraph({ spacing: { before: 600 }, children: [new TextRun({ text: "________________________", size: 22 })] }),
                    new Paragraph({ children: [new TextRun({ text: "Signature & Date", size: 18, color: "888888" })] }),
                  ]
                }),
                new TableCell({
                  width: { size: 50, type: WidthType.PERCENTAGE },
                  children: [
                    new Paragraph({ children: [new TextRun({ text: "Educator:", bold: true, size: 22 })] }),
                    new Paragraph({ spacing: { before: 600 }, children: [new TextRun({ text: "________________________", size: 22 })] }),
                    new Paragraph({ children: [new TextRun({ text: "Signature & Date", size: 18, color: "888888" })] }),
                  ]
                }),
              ]})
            ]
          })

        ]
      }]
    });

    // ── Pack and download ──
    const blob = await Packer.toBlob(doc);
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    const edName = document.getElementById('educator').value.replace(/\s+/g, '_') || 'Report';
    const dt = document.getElementById('date').value || 'date';
    link.download = `Workbook_Monitoring_${edName}_${dt}.docx`;
    link.click();
    showToast('✅ Downloading your .docx file…');
  }
</script>
</body>
</html>
