// ── UPLOAD / DROP (wired in DOMContentLoaded) ─────────


async function handleFile(file){
  var name = file.name.toLowerCase();
  showLoading('Reading file…');
  try{
    if(name.endsWith('.xlsx')||name.endsWith('.xls')) await parseXLSX(file);
    else if(name.endsWith('.pdf'))                    await parsePDF(file);
    else if(name.endsWith('.docx')||name.endsWith('.doc')) await parseDOCX(file);
    else throw new Error('Unsupported file type.');
    if(lessons.length===0) showWarn('⚠️ No lesson rows detected. Check your file matches the ATP tracker format.');
    hideLoading();
    showApp(name);
    toast('✓ '+lessons.length+' lessons loaded from '+file.name);
  }catch(err){ hideLoading(); toast('Error: '+err.message, true); }
}

// ── PARSERS ───────────────────────────────────────────
function parseXLSX(file){
  return new Promise(function(resolve,reject){
    var reader = new FileReader();
    reader.onload = function(e){
      try{
        var wb   = XLSX.read(e.target.result,{type:'binary',cellDates:true});
        var ws   = wb.Sheets[wb.SheetNames[0]];
        var rows = XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
        lessons  = extractFromRows(rows,'xlsx');
        renderTable(lessons); resolve();
      }catch(err){ reject(err); }
    };
    reader.onerror = function(){ reject(new Error('Could not read file.')); };
    reader.readAsBinaryString(file);
  });
}
async function parsePDF(file){
  setLoadingMsg('Extracting text from PDF…');
  var buf = await file.arrayBuffer();
  var pdf = await pdfjsLib.getDocument({data:buf}).promise;
  var allLines = [];
  for(var p=1;p<=pdf.numPages;p++){
    var page    = await pdf.getPage(p);
    var content = await page.getTextContent();
    var vp      = page.getViewport({scale:1});
    var buckets = {};
    for(var item of content.items){
      if(!item.str.trim()) continue;
      var y = Math.round(vp.height - item.transform[5]);
      var b = Math.round(y/5)*5;
      if(!buckets[b]) buckets[b]=[];
      buckets[b].push({x:item.transform[4],text:item.str});
    }
    Object.keys(buckets).sort(function(a,b){return a-b;}).forEach(function(k){
      var line = buckets[k].sort(function(a,b){return a.x-b.x;}).map(function(i){return i.text;}).join(' ').trim();
      if(line) allLines.push(line);
    });
  }
  lessons = extractFromText(allLines,'pdf'); renderTable(lessons);
}
async function parseDOCX(file){
  setLoadingMsg('Extracting text from Word document…');
  var buf    = await file.arrayBuffer();
  var result = await mammoth.extractRawText({arrayBuffer:buf});
  var lines  = result.value.split('\n').map(function(l){return l.trim();}).filter(Boolean);
  lessons = extractFromText(lines,'docx'); renderTable(lessons);
}

// ── EXTRACTION ────────────────────────────────────────
function extractFromRows(rows,src){
  var out=[],weekLabel='',weekNum=0;
  for(var row of rows){
    var c0=String(row[0]||'').trim(),c1=String(row[1]||'').trim(),c2=String(row[2]||'').trim();
    if(/week|isonto/i.test(c0)&&c0.length>10&&!isLessonNo(c1)){weekLabel=c0;weekNum++;continue;}
    var dateStr='';
    if(row[0] instanceof Date) dateStr=fmtDate(row[0]);
    else if(looksLikeDate(c0)) dateStr=c0;
    else if(/^\d{5}$/.test(c0)) dateStr=excelSerial(Number(c0));
    if(dateStr&&isLessonNo(c1)&&c2.length>8){out.push(mkLesson(dateStr,c1,c2,weekLabel||'Week '+(weekNum||1),weekNum||1,src));continue;}
    for(var o=0;o<=2;o++){
      var d=String(row[o]||'').trim(),n=String(row[o+1]||'').trim(),c=String(row[o+2]||'').trim();
      if(looksLikeDate(d)&&isLessonNo(n)&&c.length>8){out.push(mkLesson(d,n,c,weekLabel||'Week '+(weekNum||1),weekNum||1,src));break;}
    }
  }
  return out;
}
function extractFromText(lines,src){
  var out=[],weekLabel='',weekNum=0;
  for(var i=0;i<lines.length;i++){
    var line=lines[i].trim(); if(!line) continue;
    if(/isonto|week\s*\d/i.test(line)&&line.length>8){weekLabel=line;weekNum++;continue;}
    var packed=line.match(/^(\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4})\s+(\d{1,3})\s+(.{10,})/);
    if(packed){out.push(mkLesson(packed[1],packed[2],packed[3].trim(),weekLabel||'Week '+(weekNum||1),weekNum||1,src));continue;}
    if(looksLikeDate(line)){
      var n1=(lines[i+1]||'').trim(),n2=(lines[i+2]||'').trim();
      if(isLessonNo(n1)&&n2.length>8){out.push(mkLesson(line,n1,n2,weekLabel||'Week '+(weekNum||1),weekNum||1,src));i+=2;continue;}
      if(n1.length>10&&!isLessonNo(n1)){out.push(mkLesson(line,String(out.length+1),n1,weekLabel||'Week '+(weekNum||1),weekNum||1,src));i+=1;continue;}
    }
  }
  return out;
}

// ── LESSON BUILDER ────────────────────────────────────
function mkLesson(date,lessonNo,content,week,weekNum,src){
  content=content.trim();
  return {date:date,lessonNo:lessonNo,content:content,week:week,weekNum:weekNum,src:src,
          textType:deriveTextType(content),language:deriveLanguage(content),
          resources:deriveResources(content),classwork:deriveClasswork(content),
          homework:deriveHomework(content),formal:deriveFormal(content),
          pacing:'Just right',engagement:'Moderate',objectives:'Fully',
          reflection:deriveReflection(content)};
}

// ── DERIVATION FUNCTIONS ──────────────────────────────
function deriveTextType(c){
  var l=c.toLowerCase();
  if(/inoveli|novel/.test(l))                return 'Umbhalo wobuciko: Inoveli (Novel)';
  if(/inkondlo|poetry/.test(l))              return 'Umbhalo wobuciko: Inkondlo (Poetry)';
  if(/indaba emfishane|short story/.test(l)) return 'Umbhalo wobuciko: Indaba Emfishane (Short Story)';
  if(/iphephandaba|newspaper/.test(l))       return 'Umbhalo wolwazi: Iphephandaba (Newspaper article)';
  if(/ikhathuni|cartoon/.test(l))            return 'Umbhalo obukwayo: Ikhathuni (Visual text / Cartoon)';
  if(/incwadi|letter/.test(l))               return 'Imibhalo edlulisa umyalezo: Incwadi (Letter)';
  if(/eseyi|essay/.test(l))                  return 'Ukubhala: I-Eseyi';
  if(/baseline|diagnostic|remediat/.test(l)) return 'Ukuhlolwa okuqalisayo (Baseline / Diagnostic)';
  if(/revision|buyekeza/.test(l))            return 'Ukubuyekeza (Revision)';
  if(/isivivinyo|test|formal/.test(l))       return 'Ukuhlola okuhlelekile (Formal Assessment)';
  if(/ukulalela|listening/.test(l))          return 'Ukulalela Nokukhuluma (Listening & Speaking)';
  if(/ukufunda|reading/.test(l))             return 'Ukufunda Nokubukwa (Reading & Viewing)';
  if(/ukubhala|writing/.test(l))             return 'Ukubhala Nokwethula (Writing & Presenting)';
  return 'Faka uhlobo lombhalo (Enter text type)';
}
function deriveLanguage(c){
  var l=c.toLowerCase(),t=[];
  if(/ubunye|ubuningi/.test(l))        t.push('Ubunye nobuningi (Singular & Plural)');
  if(/izichasiso/.test(l))             t.push('Izichasiso (Adjectives)');
  if(/izikhuliso/.test(l))             t.push('Izikhuliso (Diminutives)');
  if(/izenzo|verb/.test(l))            t.push('Izenzo (Verbs)');
  if(/isabizwana/.test(l))             t.push('Izabizwana (Pronouns)');
  if(/inkathi/.test(l))                t.push('Inkathi (Tense)');
  if(/omqondofana/.test(l))            t.push('Omqondofana (Synonyms)');
  if(/omqondophika|aphikisan/.test(l)) t.push('Omqondophika (Antonyms)');
  if(/izisho|izaga/.test(l))           t.push('Izisho nezaga (Idioms & Proverbs)');
  if(/isifengqo|izifengqo/.test(l))    t.push('Izifengqo (Figures of speech)');
  if(/isiqalo|isijobelelo/.test(l))    t.push('Isiqalo, isijobelelo (Prefix / Suffix)');
  if(t.length===0) t.push('Izakhiwo nezimiso zolimi (Language structures & conventions)');
  return t.join('\n');
}
function deriveResources(c){
  var l=c.toLowerCase();
  var res=['DBE Workbook (IsiZulu FAL Grade '+schoolConfig.grade+')'];
  if(/novel|inoveli/.test(l))          res.push('Prescribed novel / Inoveli ebhaliwe');
  if(/poetry|inkondlo/.test(l))        res.push('Poetry anthology / Incwadi yezinkondlo');
  if(/newspaper|iphephandaba/.test(l)) res.push('Newspaper article / Iphephandaba');
  if(/cartoon|ikhathuni/.test(l))      res.push('Visual text / Isithombe');
  if(/letter|incwadi/.test(l))         res.push('Letter template / Isifanekiso sencwadi');
  if(/essay|eseyi/.test(l))            res.push('Writing frame / Isakhiwo sokubhala');
  if(/test|isivivinyo|formal/.test(l)) res.push('Assessment rubric / Irejista lokuhlola');
  res.push('Sasol Inzalo Reader · Whiteboard · Markers');
  return res.join('\n');
}
function deriveClasswork(c){
  var l=c.toLowerCase();
  if(/baseline|diagnostic/.test(l))    return 'Baseline assessment — learners complete diagnostic tasks independently to establish prior knowledge.';
  if(/revision|buyekeza/.test(l))       return 'Revision activity — learners revisit and consolidate prior learning through guided exercises and group discussion.';
  if(/isivivinyo|test|formal/.test(l))  return 'Formal Assessment Task — learners complete the formal assessment under test conditions.';
  if(/ukulalela|listening/.test(l))     return 'Listening activity — teacher reads aloud a prepared text. Learners answer comprehension questions orally and in writing.';
  if(/ukufunda|reading/.test(l))        return 'Shared reading activity — learners read the set text independently, then discuss main ideas and vocabulary in pairs.';
  if(/ukubhala|writing/.test(l))        return 'Guided writing activity — learners draft a structured piece based on the lesson topic using the writing frame provided.';
  if(/eseyi|essay/.test(l))             return 'Essay writing activity — learners plan and draft their essay in class using the approved writing frame and topic.';
  if(/incwadi|letter/.test(l))          return 'Letter writing activity — learners draft a formal/informal letter following the correct format taught in class.';
  if(/inkondlo|poetry/.test(l))         return 'Poetry analysis — learners identify poetic devices, discuss mood and theme, then respond in written form.';
  if(/inoveli|novel/.test(l))           return 'Novel study — learners read the set chapter(s), summarise key events and discuss character development.';
  return 'Learners engage with the lesson content through a structured class activity aligned to the CAPS topic. Teacher facilitates discussion and monitors understanding.';
}
function deriveHomework(c){
  var l=c.toLowerCase();
  if(/baseline|diagnostic/.test(l))    return 'None — baseline lesson.';
  if(/isivivinyo|test|formal/.test(l)) return 'None — formal assessment day.';
  if(/revision|buyekeza/.test(l))       return 'Complete the revision worksheet for today\'s topics. Bring corrections to the next lesson.';
  if(/ukulalela|listening/.test(l))     return 'Listen to a radio broadcast or podcast in isiZulu (10–15 min). Write five sentences summarising what you heard.';
  if(/ukufunda|reading/.test(l))        return 'Read the next section of the set text. Write a 5–8 sentence summary and note five new vocabulary words with meanings.';
  if(/eseyi|essay/.test(l))             return 'Complete the essay draft started in class. Final essay due next lesson. Minimum 200 words.';
  if(/incwadi|letter/.test(l))          return 'Write a final clean copy of the letter practised in class. Follow correct format and check spelling.';
  if(/inkondlo|poetry/.test(l))         return 'Learn the set poem by heart. Write a short paragraph explaining the theme in your own words.';
  if(/inoveli|novel/.test(l))           return 'Read the next assigned chapter. Prepare a brief oral summary for the next lesson.';
  if(/ukubhala|writing/.test(l))        return 'Complete the writing activity started in class. Bring the completed draft to the next lesson for peer review.';
  return 'Complete any unfinished classwork. Review today\'s lesson notes and vocabulary. Read ahead in the DBE Workbook.';
}
function deriveFormal(c){
  var l=c.toLowerCase();
  if(/task\s*1|taak\s*1/.test(l))         return 'Task 1 — '+c.trim();
  if(/task\s*2|taak\s*2/.test(l))         return 'Task 2 — '+c.trim();
  if(/task\s*3|taak\s*3/.test(l))         return 'Task 3 — '+c.trim();
  if(/task\s*4|taak\s*4/.test(l))         return 'Task 4 — '+c.trim();
  if(/isivivinyo|formal test/.test(l))    return 'Formal Test — '+c.trim();
  if(/oral|ukulalela|ukuphendula/.test(l))return 'Oral Assessment — '+c.trim();
  if(/essay|eseyi/.test(l))               return 'Written Task — Essay ('+c.trim()+')';
  if(/baseline|diagnostic/.test(l))       return 'Baseline / Diagnostic Assessment — not recorded as a formal mark.';
  return 'None this lesson — no formal assessment task.';
}
function deriveReflection(c){
  var l=c.toLowerCase();
  if(/baseline|diagnostic/.test(l))    return 'Baseline results will inform grouping and intervention planning for subsequent lessons.';
  if(/revision|buyekeza/.test(l))       return 'Monitor which topics required the most revision. Identify learners needing additional support before the next assessment.';
  if(/isivivinyo|test|formal/.test(l)) return 'Mark and record assessment. Note common errors for whole-class feedback in the next lesson.';
  if(/ukulalela|listening/.test(l))     return 'Check comprehension responses. Note learners who struggled — consider paired listening activities next time.';
  if(/inkondlo|poetry/.test(l))         return 'Note learner responses to poetic devices. Consolidate any figures of speech that caused confusion.';
  if(/eseyi|essay/.test(l))             return 'Review essay plans/drafts for structure and coherence. Provide written feedback before final submission.';
  return 'Observe learner participation and comprehension. Adjust pacing or grouping in the next lesson if objectives were not fully met.';
}

// ── RENDER TABLE ──────────────────────────────────────
var SRC_HTML = {
  xlsx:'<span class="src-badge src-xlsx">XLSX</span>',
  pdf: '<span class="src-badge src-pdf">PDF</span>',
  docx:'<span class="src-badge src-docx">DOCX</span>'
};
function renderTable(data){
  var tbody = document.getElementById('tracker-body');
  tbody.innerHTML = '';
  document.getElementById('lesson-count').textContent = data.length+' lessons';
  var lastWeek = '';
  data.forEach(function(l,idx){
    if(l.week!==lastWeek){
      var wr=document.createElement('tr'); wr.className='week-hdr';
      wr.innerHTML='<td colspan="5">📅 '+l.week+'</td>';
      tbody.appendChild(wr); lastWeek=l.week;
    }
    var tr=document.createElement('tr');
    tr.innerHTML='<td class="date-col">'+l.date+'</td>'
      +'<td class="lesson-col">'+l.lessonNo+'</td>'
      +'<td>'+l.content+'</td>'
      +'<td style="font-size:12px;color:#888;white-space:nowrap;">Wk '+l.weekNum+'</td>'
      +'<td><button class="select-btn" onclick="openForm('+idx+')">Open Form →</button></td>';
    tbody.appendChild(tr);
  });
}
