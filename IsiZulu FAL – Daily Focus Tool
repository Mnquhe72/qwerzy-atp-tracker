// ── DOWNLOAD HELPER ───────────────────────────────────
function dlBlob(blob, filename){
  var reader = new FileReader();
  reader.onloadend = function(){
    var a = document.createElement('a');
    a.href = reader.result;
    a.download = filename;
    a.style.display = 'none';
    document.body.appendChild(a);
