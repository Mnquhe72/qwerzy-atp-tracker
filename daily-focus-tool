function deriveFocus(c,sub){
  var l=c.toLowerCase();
  if(isLanguage(sub)){
    if(/novel|inoveli/.test(l))                return 'Literary Text: Novel';
    if(/poetry|inkondlo|poem/.test(l))         return 'Literary Text: Poetry';
    if(/short story|indaba emfishane/.test(l)) return 'Literary Text: Short Story';
    if(/newspaper|iphephandaba/.test(l))       return 'Informational Text: Newspaper Article';
    if(/cartoon|visual|ikhathuni/.test(l))     return 'Visual Text: Cartoon / Image';
    if(/letter|incwadi/.test(l))               return 'Transactional Text: Letter';
    if(/essay|eseyi/.test(l))                  return 'Writing: Essay';
    if(/report/.test(l))                       return 'Writing: Report';
    if(/speech/.test(l))                       return 'Oral: Speech / Presentation';
    if(/listening|ukulalela/.test(l))          return 'Listening & Speaking';
    if(/reading|ukufunda/.test(l))             return 'Reading & Viewing';
    if(/writing|ukubhala/.test(l))             return 'Writing & Presenting';
    if(/baseline|diagnostic/.test(l))         return 'Baseline / Diagnostic Assessment';
    if(/revision|buyekeza/.test(l))            return 'Revision';
    if(/test|formal|isivivinyo/.test(l))       return 'Formal Assessment';
    return 'Language: '+capFirst(c);
  }
  // Non-language: derive focus directly from the content string
  if(/baseline|diagnostic/.test(l)) return 'Baseline / Diagnostic Assessment';
  if(/revision/.test(l))            return 'Revision: '+capFirst(c);
  if(/test|exam|assessment/.test(l))return 'Formal Assessment: '+capFirst(c);
  // Return a cleaned version of the content as the focus
  return capFirst(c.length>80 ? c.substring(0,80)+'…' : c);
}

