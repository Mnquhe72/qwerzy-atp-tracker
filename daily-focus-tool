    sigHod:         gv('sig-hod-name'),    sigHodDate: gv('sig-hod-date')
  };
}
function gv(id){ var el=document.getElementById(id); return el?el.value||'':''; }
function nl(s){ return (s||'').replace(/\n/g,'<br/>'); }

function exportAs(fmt){
  closeExport();
  var d=collectForm(), subj=getSubj();
  var fname='DailyFocus_'+subj.name.replace(/[^a-zA-Z0-9]/g,'')+'_'+d.date.replace(/\//g,'-')+'_'+d.lessonNo.replace('Lesson ','L');
  if(fmt==='pdf') exportPDF(d,fname,subj);
  else if(fmt==='docx') exportDOCX(d,fname,subj);
  else if(fmt==='xlsx') exportXLSX(d,fname,subj);
  else if(fmt==='csv')  exportCSV(d,fname);
