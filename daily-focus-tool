    return 'Revision activity — learners revisit and consolidate prior learning through guided exercises and peer discussion.';
  if(/test|formal assessment|exam/.test(l))
    return 'Formal Assessment — learners complete the assessment under supervised conditions.';
  if(isLanguage(sub)){
    if(/listening/.test(l))  return 'Listening activity — teacher reads aloud a prepared text. Learners answer comprehension questions orally and in writing.';
    if(/reading/.test(l))    return 'Shared reading activity — learners read the set text, identify key ideas and discuss vocabulary in pairs.';
    if(/writing/.test(l))    return 'Guided writing activity — learners draft a structured piece using the writing frame and topic provided.';
    if(/essay/.test(l))      return 'Essay writing — learners plan and draft their essay using the approved writing frame.';
