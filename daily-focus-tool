// ── EXPORT: XLSX ──────────────────────────────────────
function exportXLSX(d,fname,subj){
  var subtitle=document.getElementById('form-subtitle').textContent;
  var rows=[
    [subj.name.toUpperCase()+' DAILY FOCUS FORM',''],
    [subtitle,''],['',''],
    ['Teacher',d.teacher],['Week',d.week],['Grade',d.grade],['',''],
    ['Field','Value'],
    ['Date',d.date],['Lesson Number',d.lessonNo],
    [subj.focus,d.textType],[subj.content,d.content],
    ['Resources',d.resources],[subj.concepts,d.language],
    ['In-class Activity',d.classwork],['Homework',d.homework],
    ['Formal Assessment Task',d.formal],
    ['Lesson Pacing',d.pacing],['Learner Engagement',d.engagement],
    ['Objectives Met',d.objectives],['Reflection',d.reflection],['',''],
    ['SIGN-OFF',''],
    ['Teacher',d.sigTeacher+'    Date: '+d.sigTeacherDate],
    ['HoD/Supervisor',d.sigHod+'    Date: '+d.sigHodDate]
  ];
  var ws=XLSX.utils.aoa_to_sheet(rows);
  ws['!cols']=[{wch:32},{wch:64}];
  var wb=XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb,ws,'Daily Focus');
  XLSX.writeFile(wb,fname+'.xlsx');
  toast('✓ Excel file downloaded');
}

