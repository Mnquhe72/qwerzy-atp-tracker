  var l=c.toLowerCase();
  if(/baseline|diagnostic/.test(l))  return 'Baseline results will inform grouping and differentiated support planning for subsequent lessons.';
  if(/revision/.test(l))             return 'Note which topics required the most revision. Identify learners needing additional support before the next assessment.';
  if(/test|formal|exam/.test(l))     return 'Mark and record assessment results. Identify common errors for whole-class feedback in the next lesson.';
  if(/practical|experiment/.test(l)) return 'Assess the quality of practical write-ups. Note any safety or procedural issues to address in the next practical.';
  if(isLanguage(sub)){
    if(/writing|essay/.test(l)) return 'Review drafts for structure and coherence. Provide written feedback before final submission.';
    if(/reading/.test(l))       return 'Note comprehension levels and vocabulary gaps. Adjust reading support strategies as needed.';
    return 'Observe learner participation and language use. Note any recurring errors for explicit teaching in the next lesson.';
  }
  if(sub==='mathematics'||sub==='mathematical-literacy')
    return 'Identify learners who struggled with key concepts. Plan targeted support or re-teaching for the next lesson if objectives were not fully met.';
  return 'Observe learner participation and understanding. Adjust pacing, grouping or teaching strategy in the next lesson if objectives were not fully met.';
}

// ── HELPERS ───────────────────────────────────────────
function deriveExerciseRef(c){
  var m=c.match(/\d+[\.\d]*/);
  return m ? m[0] : 'from today\'s lesson';
}
function capFirst(s){ return s ? s.charAt(0).toUpperCase()+s.slice(1) : ''; }
function looksLikeDate(s){ return /^\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4}$/.test(s.trim()); }
function isLessonNo(s){    return /^\d{1,3}$/.test(s.trim()); }
function fmtDate(d){       return String(d.getDate()).padStart(2,'0')+'/'+String(d.getMonth()+1).padStart(2,'0')+'/'+d.getFullYear(); }
function excelSerial(n){   var d=XLSX.SSF.parse_date_code(n); return d?String(d.d).padStart(2,'0')+'/'+String(d.m).padStart(2,'0')+'/'+d.y:String(n); }

// ── RENDER TABLE ──────────────────────────────────────
var SRC_HTML={
  xlsx:'<span class="src-badge src-xlsx">XLSX</span>',
  pdf: '<span class="src-badge src-pdf">PDF</span>',
  docx:'<span class="src-badge src-docx">DOCX</span>'
};
function renderTable(data){
  var tbody=document.getElementById('tracker-body');
  tbody.innerHTML='';
  document.getElementById('lesson-count').textContent=data.length+' lessons';
  var lastWeek='';
  data.forEach(function(l,idx){
    if(l.week!==lastWeek){
      var wr=document.createElement('tr'); wr.className='week-hdr';
      wr.innerHTML='<td colspan="5">📅 '+l.week+'</td>';
      tbody.appendChild(wr); lastWeek=l.week;
    }
    var tr=document.createElement('tr');
    tr.innerHTML='<td class="date-col">'+l.date+'</td>'
      +'<td class="lesson-col">'+l.lessonNo+'</td>'
      +'<td>'+l.content+'</td>'
      +'<td style="font-size:12px;color:#888;white-space:nowrap;">Wk '+l.weekNum+'</td>'
      +'<td><button class="select-btn" data-idx="'+idx+'">Open Form →</button></td>';
    tbody.appendChild(tr);
  });
  // Wire table buttons
  tbody.querySelectorAll('.select-btn').forEach(function(btn){
    btn.addEventListener('click',function(){ openForm(parseInt(this.getAttribute('data-idx'))); });
  });
}

// ── OPEN FORM ─────────────────────────────────────────
function openForm(idx){
  var l=lessons[idx];
  document.getElementById('f-date').value         = l.date;
  document.getElementById('f-lesson-no').value    = 'Lesson '+l.lessonNo;
  document.getElementById('f-text-type').value    = l.textType;
  document.getElementById('f-content').value      = l.content;
  document.getElementById('f-language').value     = l.language;
  document.getElementById('f-resources').value    = l.resources;
  document.getElementById('f-classwork').value    = l.classwork;
  document.getElementById('f-homework').value     = l.homework;
  document.getElementById('f-formal').value       = l.formal;
  document.getElementById('f-self-reflect').value = l.reflection;
  document.getElementById('meta-week').value      = l.week;
  setSelect('sa-pacing',    l.pacing);
  setSelect('sa-engage',    l.engagement);
  setSelect('sa-objectives',l.objectives);
  var s=schoolConfig;
  if(s.teacher){ document.getElementById('meta-teacher').value=s.teacher; document.getElementById('sig-teacher-name').value=s.teacher; }
  document.getElementById('meta-class').value='Grade '+s.grade;
  var today=new Date();
  document.getElementById('sig-teacher-date').value=
    today.getFullYear()+'-'+String(today.getMonth()+1).padStart(2,'0')+'-'+String(today.getDate()).padStart(2,'0');
  clearCanvas('teacher-sig-canvas'); clearCanvas('hod-sig-canvas');
  document.getElementById('step2').className='step done';
  document.getElementById('step3').className='step active';
  document.getElementById('panel-table').classList.remove('active');
  document.getElementById('panel-form').classList.add('active');
  setTimeout(function(){ document.querySelector('.sig-section').scrollIntoView({behavior:'smooth',block:'start'}); },150);
}
function setSelect(id,val){
  var sel=document.getElementById(id);
  for(var i=0;i<sel.options.length;i++){ if(sel.options[i].text===val){sel.selectedIndex=i;return;} }
}

// ── NAVIGATION ────────────────────────────────────────
function showTable(){
  document.getElementById('panel-form').classList.remove('active');
  document.getElementById('panel-table').classList.add('active');
  document.getElementById('step3').className='step';
  window.scrollTo({top:0,behavior:'smooth'});
}
function showApp(filename){
  document.getElementById('upload-panel').style.display='none';
  document.getElementById('app').style.display='block';
  var ext=filename.endsWith('.pdf')?'pdf':(filename.endsWith('.docx')||filename.endsWith('.doc'))?'docx':'xlsx';
  document.getElementById('src-badge-wrap').innerHTML=SRC_HTML[ext]||'';
}

// ── LOADING ───────────────────────────────────────────
function showLoading(msg){ document.getElementById('loading-msg').textContent=msg; document.getElementById('loading').classList.add('show'); }
function setLoadingMsg(m){ document.getElementById('loading-msg').textContent=m; }
function hideLoading(){    document.getElementById('loading').classList.remove('show'); }
function showWarn(msg){    var b=document.getElementById('warn-banner'); b.textContent=msg; b.classList.add('show'); }

// ── CANVASES ──────────────────────────────────────────
function initCanvas(id){
  var canvas=document.getElementById(id),ctx=canvas.getContext('2d');
  var drawing=false,lx=0,ly=0;
  function resize(){ canvas.width=canvas.parentElement.offsetWidth||300; canvas.height=80; }
  resize();
  ctx.strokeStyle='#0f1923'; ctx.lineWidth=1.8; ctx.lineCap='round'; ctx.lineJoin='round';
  function pt(e){ var r=canvas.getBoundingClientRect(),sx=canvas.width/r.width,sy=canvas.height/r.height,s=e.touches?e.touches[0]:e; return{x:(s.clientX-r.left)*sx,y:(s.clientY-r.top)*sy}; }
  canvas.addEventListener('mousedown',  function(e){ drawing=true; var p=pt(e); lx=p.x; ly=p.y; });
  canvas.addEventListener('mousemove',  function(e){ if(!drawing)return; var p=pt(e); ctx.beginPath(); ctx.moveTo(lx,ly); ctx.lineTo(p.x,p.y); ctx.stroke(); lx=p.x; ly=p.y; });
  canvas.addEventListener('mouseup',    function(){ drawing=false; });
  canvas.addEventListener('mouseleave', function(){ drawing=false; });
  canvas.addEventListener('touchstart', function(e){ e.preventDefault(); drawing=true; var p=pt(e); lx=p.x; ly=p.y; },{passive:false});
  canvas.addEventListener('touchmove',  function(e){ e.preventDefault(); if(!drawing)return; var p=pt(e); ctx.beginPath(); ctx.moveTo(lx,ly); ctx.lineTo(p.x,p.y); ctx.stroke(); lx=p.x; ly=p.y; },{passive:false});
  canvas.addEventListener('touchend',   function(){ drawing=false; });
}
function clearCanvas(id){ var c=document.getElementById(id); c.getContext('2d').clearRect(0,0,c.width,c.height); }

// ── TOAST ─────────────────────────────────────────────
function toast(msg,isErr){
  var t=document.getElementById('toast');
  t.textContent=msg; t.className='toast'+(isErr?' error':'');
  t.classList.add('show'); setTimeout(function(){ t.classList.remove('show'); },3500);
}

// ── SAFE EVENT BINDER ─────────────────────────────────
function on(id,evt,fn){ var el=document.getElementById(id); if(el) el.addEventListener(evt,fn); }

// ── DOM READY ─────────────────────────────────────────
document.addEventListener('DOMContentLoaded',function(){
  on('btn-setup-save',    'click', saveSetup);
  on('header-badge',      'click', openSetup);
  on('btn-export-open',   'click', openExport);
  on('btn-export-cancel', 'click', closeExport);
  on('exp-pdf',  'click', function(){ exportAs('pdf');  });
  on('exp-docx', 'click', function(){ exportAs('docx'); });
  on('exp-xlsx', 'click', function(){ exportAs('xlsx'); });
  on('exp-csv',  'click', function(){ exportAs('csv');  });
  on('btn-back-top',      'click', showTable);
  on('btn-back-bottom',   'click', showTable);
  on('clear-teacher-sig', 'click', function(){ clearCanvas('teacher-sig-canvas'); });
  on('clear-hod-sig',     'click', function(){ clearCanvas('hod-sig-canvas'); });
  on('search-input','input',function(){
    var q=this.value.toLowerCase();
    renderTable(lessons.filter(function(l){
      return l.date.toLowerCase().includes(q)||l.content.toLowerCase().includes(q)||String(l.lessonNo).includes(q);
    }));
  });
  var dz=document.getElementById('drop-zone'),fi=document.getElementById('file-input');
  if(dz){
    dz.addEventListener('dragover',  function(e){ e.preventDefault(); dz.classList.add('drag-over'); });
    dz.addEventListener('dragleave', function(){ dz.classList.remove('drag-over'); });
    dz.addEventListener('drop',      function(e){ e.preventDefault(); dz.classList.remove('drag-over'); if(e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); });
  }
  if(fi) fi.addEventListener('change',function(e){ if(e.target.files[0]) handleFile(e.target.files[0]); });
  initCanvas('teacher-sig-canvas');
  initCanvas('hod-sig-canvas');
});
</script>
