<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Daily Focus Tool</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
:root{--ink:#0f1923;--paper:#faf7f2;--cream:#f3ede3;--green:#1a5276;--green-mid:#1e8449;--green-lt:#d5f5e3;--gold:#c8973a;--gold-lt:#fef3e0;--red:#922b21;--border:#c8bfb0;--shadow:rgba(15,25,35,0.12);}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--paper);color:var(--ink);min-height:100vh;}
.modal-overlay{position:fixed;inset:0;background:rgba(15,25,35,.6);z-index:900;display:flex;align-items:center;justify-content:center;padding:24px;}
.modal-overlay.hidden{display:none;}
.modal-card{background:#fff;border-radius:20px;padding:40px;max-width:480px;width:100%;box-shadow:0 12px 48px rgba(15,25,35,.25);max-height:90vh;overflow-y:auto;}
.modal-card h2{font-family:'Playfair Display',serif;font-size:24px;margin-bottom:6px;color:var(--green);}
.modal-card p{font-size:13px;color:#666;margin-bottom:24px;line-height:1.6;}
.setup-field{margin-bottom:18px;}
.setup-field label{display:block;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#999;margin-bottom:6px;}
.setup-field input,.setup-field select{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;background:#fafafa;color:var(--ink);transition:.2s;}
.setup-field input:focus,.setup-field select:focus{border-color:var(--green);background:#fff;}
.setup-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.modal-btn{width:100%;padding:13px;background:var(--green);color:#fff;border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:.2s;margin-top:8px;}
.modal-btn:hover{background:var(--green-mid);}
.export-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;}
.exp-btn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:18px 10px;border:1.5px solid var(--border);border-radius:12px;background:#fafafa;cursor:pointer;font-family:'DM Sans',sans-serif;transition:.2s;text-align:center;}
.exp-btn:hover{border-color:var(--green);background:var(--green-lt);color:var(--green);}
.exp-btn .ei{font-size:26px;}.exp-btn .el{font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;}.exp-btn .es{font-size:10px;color:#888;}
.exp-cancel{width:100%;padding:10px;background:transparent;border:1.5px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;color:#888;transition:.2s;}
.exp-cancel:hover{border-color:var(--red);color:var(--red);}
header{background:var(--green);color:#fff;padding:18px 32px;display:flex;align-items:center;gap:16px;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px var(--shadow);}
.header-logo{width:44px;height:44px;background:var(--gold);border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:20px;font-weight:900;color:var(--green);flex-shrink:0;}
header h1{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;}
header p{font-size:12px;opacity:.75;margin-top:2px;}
.header-badge{margin-left:auto;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);border-radius:20px;padding:4px 14px;font-size:11px;font-family:'DM Mono',monospace;cursor:pointer;transition:.2s;white-space:nowrap;}
.header-badge:hover{background:rgba(255,255,255,.25);}
#upload-panel{max-width:680px;margin:60px auto;padding:0 24px;}
.upload-card{background:#fff;border:2px dashed var(--border);border-radius:20px;padding:52px 40px;text-align:center;transition:.25s;}
.upload-card:hover,.upload-card.drag-over{border-color:var(--green-mid);background:var(--green-lt);}
.upload-icon{width:72px;height:72px;background:var(--green-lt);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 22px;font-size:32px;}
.upload-card h2{font-family:'Playfair Display',serif;font-size:24px;margin-bottom:8px;}
.upload-card p{color:#666;font-size:14px;line-height:1.65;}
.fmt-strip{display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin:22px 0 4px;}
.fmt-badge{padding:5px 16px;border-radius:20px;font-size:11px;font-weight:700;font-family:'DM Mono',monospace;border:1px solid;}
.fmt-xlsx{background:#e8f8f0;color:#1e8449;border-color:#a8dbbe;}
.fmt-pdf{background:#fdecea;color:#c0392b;border-color:#f5b7b1;}
.fmt-docx{background:#eaf0ff;color:#1a5276;border-color:#a9c4e8;}
.upload-btn{display:inline-block;margin-top:26px;padding:13px 32px;background:var(--green);color:#fff;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;transition:.2s;}
.upload-btn:hover{background:var(--green-mid);}
#file-input{display:none;}
#loading{display:none;position:fixed;inset:0;background:rgba(15,25,35,.55);z-index:500;align-items:center;justify-content:center;flex-direction:column;gap:16px;}
#loading.show{display:flex;}
.spinner{width:48px;height:48px;border:4px solid rgba(255,255,255,.2);border-top-color:#fff;border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.loading-msg{color:#fff;font-size:14px;font-weight:500;}
#app{display:none;max-width:1100px;margin:0 auto;padding:32px 24px 80px;}
.steps{display:flex;margin-bottom:38px;background:#fff;border-radius:14px;border:1px solid var(--border);overflow:hidden;}
.step{flex:1;padding:14px 18px;display:flex;align-items:center;gap:10px;font-size:13px;font-weight:500;color:#888;border-right:1px solid var(--border);transition:.2s;}
.step:last-child{border-right:none;}
.step.active{background:var(--green-lt);color:var(--green);}
.step.done{background:var(--green);color:#fff;}
.step-num{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'DM Mono',monospace;font-size:11px;font-weight:600;background:rgba(0,0,0,.1);flex-shrink:0;}
.step.active .step-num{background:var(--green);color:#fff;}
.step.done .step-num{background:rgba(255,255,255,.3);color:#fff;}
.panel{display:none;}.panel.active{display:block;}
.tracker-bar{display:flex;align-items:center;gap:14px;margin-bottom:18px;flex-wrap:wrap;}
.tracker-bar h2{font-family:'Playfair Display',serif;font-size:22px;}
.lesson-count{background:var(--green-lt);color:var(--green);border-radius:20px;padding:4px 14px;font-size:12px;font-family:'DM Mono',monospace;}
.tracker-search{margin-left:auto;padding:8px 16px;border:1px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;width:220px;outline:none;}
.tracker-search:focus{border-color:var(--green);}
.src-badge{font-size:11px;font-family:'DM Mono',monospace;padding:3px 10px;border-radius:12px;font-weight:700;border:1px solid;}
.src-xlsx{background:#e8f8f0;color:#1e8449;border-color:#a8dbbe;}
.src-pdf{background:#fdecea;color:#c0392b;border-color:#f5b7b1;}
.src-docx{background:#eaf0ff;color:#1a5276;border-color:#a9c4e8;}
.warn-banner{background:#fff8e1;border:1px solid #ffe082;border-radius:10px;padding:12px 18px;font-size:13px;color:#7b5a00;margin-bottom:18px;display:none;}
.warn-banner.show{display:block;}
.tracker-table-wrap{overflow-x:auto;border-radius:14px;border:1px solid var(--border);}
table{width:100%;border-collapse:collapse;font-size:13px;}
thead th{background:var(--green);color:#fff;padding:12px 14px;text-align:left;font-weight:600;font-size:12px;white-space:nowrap;}
tbody tr{border-bottom:1px solid var(--border);transition:.15s;}
tbody tr:hover{background:var(--cream);}
tbody tr.week-hdr{background:var(--green-lt);}
tbody tr.week-hdr td{font-weight:700;color:var(--green);font-size:12px;padding:8px 14px;}
tbody td{padding:10px 14px;vertical-align:middle;}
.date-col{font-family:'DM Mono',monospace;font-size:12px;white-space:nowrap;color:var(--green-mid);font-weight:600;}
.lesson-col{text-align:center;font-family:'DM Mono',monospace;font-size:12px;}
.select-btn{padding:5px 14px;background:var(--green);color:#fff;border:none;border-radius:6px;font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:600;transition:.2s;white-space:nowrap;}
.select-btn:hover{background:var(--green-mid);}
.form-topbar{display:flex;align-items:center;gap:16px;margin-bottom:28px;flex-wrap:wrap;}
.form-topbar h2{font-family:'Playfair Display',serif;font-size:22px;}
.back-btn{padding:8px 18px;background:var(--cream);border:1px solid var(--border);border-radius:8px;font-size:13px;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:500;}
.back-btn:hover{background:#e8e0d4;}
.daily-form{background:#fff;border:1.5px solid var(--border);border-radius:18px;overflow:hidden;box-shadow:0 6px 32px var(--shadow);max-width:820px;margin:0 auto;}
.form-header{background:var(--green);color:#fff;padding:20px 32px;}
.form-header h3{font-family:'Playfair Display',serif;font-size:22px;}
.form-header p{font-size:12px;opacity:.75;margin-top:4px;}
.form-meta{display:grid;grid-template-columns:repeat(3,1fr);border-bottom:2px solid var(--border);}
.meta-field{padding:14px 20px;border-right:1px solid var(--border);}
.meta-field:last-child{border-right:none;}
.meta-label{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#999;margin-bottom:4px;}
.meta-input{width:100%;border:none;border-bottom:1.5px solid var(--border);padding:4px 0;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;outline:none;background:transparent;color:var(--ink);transition:.2s;}
.meta-input:focus{border-color:var(--green);}
.form-row{display:grid;grid-template-columns:220px 1fr;border-bottom:1px solid var(--border);}
.form-row:last-child{border-bottom:none;}
.row-label{padding:14px 20px;background:var(--cream);border-right:1px solid var(--border);font-weight:700;font-size:12px;display:flex;flex-direction:column;align-items:flex-start;line-height:1.4;}
.row-label small{display:block;font-weight:400;font-size:10px;color:#888;margin-top:2px;}
.row-value{padding:12px 18px;display:flex;align-items:flex-start;}
.row-textarea{width:100%;min-height:56px;border:1px solid var(--border);border-radius:6px;padding:8px 12px;font-family:'DM Sans',sans-serif;font-size:13px;line-height:1.6;resize:vertical;outline:none;background:#fafafa;transition:.2s;color:var(--ink);}
.row-textarea:focus{border-color:var(--green);background:#fff;}
.row-textarea.prefilled{background:var(--green-lt);border-color:#a8dbbe;}
.assess-grid{width:100%;display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.assess-item label{font-size:11px;font-weight:600;color:#666;display:block;margin-bottom:4px;}
.self-assess-grid{width:100%;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
.sa-item label{font-size:11px;font-weight:600;color:#666;display:block;margin-bottom:4px;}
.sa-select{width:100%;padding:6px 10px;border:1px solid var(--border);border-radius:6px;font-family:'DM Sans',sans-serif;font-size:13px;background:#fafafa;outline:none;cursor:pointer;}
.sa-select.prefilled{background:var(--green-lt);border-color:#a8dbbe;}
.sign-banner{background:var(--green-lt);border:1.5px solid #a8dbbe;border-radius:10px;padding:12px 20px;font-size:13px;color:var(--green);font-weight:600;display:flex;align-items:center;gap:10px;}
.sig-section{border-top:2px solid var(--green);padding:24px 24px 8px;background:var(--gold-lt);}
.sig-section-title{font-size:12px;font-weight:700;color:var(--green);margin-bottom:16px;letter-spacing:.03em;text-transform:uppercase;}
.sig-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px 32px;margin-bottom:16px;}
.sig-block label{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#888;display:block;margin-bottom:6px;}
.sig-line{width:100%;border:none;border-bottom:1.5px solid var(--ink);padding:4px 0;font-family:'DM Sans',sans-serif;font-size:14px;background:transparent;outline:none;min-height:32px;}
.sig-canvas-wrap{border:1px dashed var(--border);border-radius:8px;background:#fff;position:relative;height:80px;overflow:hidden;cursor:crosshair;}
.sig-canvas-wrap canvas{width:100%;height:100%;display:block;touch-action:none;}
.sig-clear{position:absolute;top:6px;right:8px;font-size:10px;color:#aaa;cursor:pointer;background:rgba(255,255,255,.8);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:'DM Sans',sans-serif;}
.sig-clear:hover{color:var(--red);border-color:var(--red);}
.action-bar{display:flex;gap:12px;justify-content:flex-end;padding:20px 24px;border-top:1px solid var(--border);background:var(--cream);flex-wrap:wrap;}
.btn{padding:11px 26px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;border:none;transition:.2s;}
.btn-gold{background:var(--gold);color:#fff;}.btn-gold:hover{opacity:.9;}
.btn-outline{background:transparent;border:1.5px solid var(--border);color:var(--ink);}.btn-outline:hover{border-color:var(--green);color:var(--green);}
.toast{position:fixed;bottom:32px;left:50%;transform:translateX(-50%) translateY(60px);background:var(--green);color:#fff;padding:12px 28px;border-radius:30px;font-size:13px;font-weight:600;box-shadow:0 4px 20px rgba(0,0,0,.2);transition:transform .3s cubic-bezier(.34,1.56,.64,1);z-index:999;white-space:nowrap;}
.toast.show{transform:translateX(-50%) translateY(0);}
.toast.error{background:var(--red);}
@media print{
  header,.steps,.form-topbar,.action-bar,#upload-panel,.tracker-bar,.tracker-table-wrap,
  .back-btn,.sig-clear,#loading,.modal-overlay,.sign-banner{display:none!important;}
  body{background:#fff;}#app{padding:0;max-width:100%;}
  .panel{display:block!important;}#panel-table{display:none!important;}
  .daily-form{box-shadow:none;border:1px solid #ccc;border-radius:0;}
}
@media(max-width:600px){
  .form-meta,.setup-row{grid-template-columns:1fr;}
  .meta-field{border-right:none;border-bottom:1px solid var(--border);}
  .form-row{grid-template-columns:1fr;}
  .row-label{border-right:none;border-bottom:1px solid var(--border);}
  .sig-grid,.assess-grid,.export-grid{grid-template-columns:1fr 1fr;}
  .self-assess-grid{grid-template-columns:1fr 1fr;}
  .steps{display:none;}
}
</style>
</head>
<body>

<!-- SETUP MODAL -->
<div id="setup-modal" class="modal-overlay">
  <div class="modal-card">
    <h2>School Details</h2>
    <p>These details will be pre-filled on every Daily Focus Form. Click the badge in the top-right to update at any time.</p>
    <div class="setup-field">
      <label>School Name</label>
      <input type="text" id="setup-school" placeholder="e.g. Greenfields Primary School"/>
    </div>
    <div class="setup-field">
      <label>Subject</label>
      <select id="setup-subject">
        <optgroup label="Languages">
          <option value="isizulu-fal">IsiZulu FAL</option>
          <option value="isizulu-hl">IsiZulu HL</option>
          <option value="english-fal">English FAL</option>
          <option value="english-hl">English HL</option>
          <option value="afrikaans-fal">Afrikaans FAL</option>
          <option value="afrikaans-hl">Afrikaans HL</option>
          <option value="language-other">Other Language</option>
        </optgroup>
        <optgroup label="Mathematics">
          <option value="mathematics">Mathematics</option>
          <option value="mathematical-literacy">Mathematical Literacy</option>
        </optgroup>
        <optgroup label="Sciences">
          <option value="natural-sciences">Natural Sciences</option>
          <option value="physical-sciences">Physical Sciences</option>
          <option value="life-sciences">Life Sciences</option>
        </optgroup>
        <optgroup label="Humanities">
          <option value="social-sciences">Social Sciences</option>
          <option value="history">History</option>
          <option value="geography">Geography</option>
        </optgroup>
        <optgroup label="Other CAPS Subjects">
          <option value="technology">Technology</option>
          <option value="ems">Economic & Management Sciences</option>
          <option value="arts-culture">Arts & Culture / Creative Arts</option>
          <option value="life-orientation">Life Orientation</option>
          <option value="accounting">Accounting</option>
          <option value="business-studies">Business Studies</option>
          <option value="computer-applications">Computer Applications Technology</option>
          <option value="engineering-graphics">Engineering Graphics & Design</option>
          <option value="agriculture">Agricultural Sciences</option>
          <option value="tourism">Tourism</option>
          <option value="consumer-studies">Consumer Studies</option>
          <option value="religion-studies">Religion Studies</option>
        </optgroup>
      </select>
    </div>
    <div class="setup-row">
      <div class="setup-field">
        <label>Grade</label>
        <select id="setup-grade">
          <option value="R">Grade R</option>
          <option value="1">Grade 1</option><option value="2">Grade 2</option><option value="3">Grade 3</option>
          <option value="4">Grade 4</option><option value="5">Grade 5</option><option value="6">Grade 6</option>
          <option value="7" selected>Grade 7</option>
          <option value="8">Grade 8</option><option value="9">Grade 9</option>
          <option value="10">Grade 10</option><option value="11">Grade 11</option><option value="12">Grade 12</option>
        </select>
      </div>
      <div class="setup-field">
        <label>Academic Year</label>
        <input type="text" id="setup-year" value="2026"/>
      </div>
    </div>
    <div class="setup-field">
      <label>Teacher Name</label>
      <input type="text" id="setup-teacher" placeholder="Full name…"/>
    </div>
    <button class="modal-btn" id="btn-setup-save">Continue →</button>
  </div>
</div>

<!-- EXPORT MODAL -->
<div id="export-modal" class="modal-overlay hidden">
  <div class="modal-card">
    <h2>Export Daily Focus Form</h2>
    <p>Choose your preferred format to save or share this form.</p>
    <div class="export-grid">
      <button class="exp-btn" id="exp-pdf"><span class="ei">📄</span><span class="el">PDF</span><span class="es">Print-ready</span></button>
      <button class="exp-btn" id="exp-docx"><span class="ei">📝</span><span class="el">Word / DOCX</span><span class="es">Editable document</span></button>
      <button class="exp-btn" id="exp-xlsx"><span class="ei">📊</span><span class="el">Excel / XLSX</span><span class="es">Spreadsheet record</span></button>
      <button class="exp-btn" id="exp-csv"><span class="ei">🟢</span><span class="el">Google Sheets</span><span class="es">CSV for import</span></button>
    </div>
    <button class="exp-cancel" id="btn-export-cancel">Cancel</button>
  </div>
</div>

<!-- Loading -->
<div id="loading">
  <div class="spinner"></div>
  <div class="loading-msg" id="loading-msg">Reading file…</div>
</div>

<header>
  <div class="header-logo">Q</div>
  <div>
    <h1 id="header-title">Daily Focus Tool</h1>
    <p id="header-sub">CAPS ATP Tracker — aligned daily planning</p>
  </div>
  <div class="header-badge" id="header-badge" title="Click to edit school details">GRADE 7 · 2026</div>
</header>

<!-- UPLOAD -->
<div id="upload-panel">
  <div class="upload-card" id="drop-zone">
    <div class="upload-icon">📋</div>
    <h2>Upload Your ATP Tracker</h2>
    <p>Drop your tracker file and every field on the Daily Focus Form will be prefilled automatically. The educator only needs to sign.</p>
    <div class="fmt-strip">
      <span class="fmt-badge fmt-xlsx">XLSX · XLS</span>
      <span class="fmt-badge fmt-pdf">PDF</span>
      <span class="fmt-badge fmt-docx">DOCX · DOC</span>
    </div>
    <p style="font-size:12px;color:#aaa;margin-top:10px;">Drag &amp; drop or click to browse</p>
    <label class="upload-btn" for="file-input">Choose Tracker File</label>
    <input type="file" id="file-input" accept=".xlsx,.xls,.pdf,.docx,.doc"/>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="steps">
    <div class="step done"   id="step1"><div class="step-num">✓</div>Upload Tracker</div>
    <div class="step active" id="step2"><div class="step-num">2</div>Select Lesson</div>
    <div class="step"        id="step3"><div class="step-num">3</div>Review &amp; Sign</div>
    <div class="step"        id="step4"><div class="step-num">4</div>Export</div>
  </div>

  <!-- LESSON TABLE -->
  <div class="panel active" id="panel-table">
    <div class="warn-banner" id="warn-banner"></div>
    <div class="tracker-bar">
      <div>
        <h2>Lesson Schedule</h2>
        <p style="font-size:13px;color:#666;margin-top:3px;">Select a lesson — the form will be fully prefilled and ready to sign</p>
      </div>
      <span class="lesson-count" id="lesson-count">0 lessons</span>
      <span id="src-badge-wrap"></span>
      <input type="text" class="tracker-search" id="search-input" placeholder="Search date or topic…"/>
    </div>
    <div class="tracker-table-wrap">
      <table>
        <thead><tr><th>Date</th><th>No.</th><th>Content / Activity</th><th>Week</th><th>Action</th></tr></thead>
        <tbody id="tracker-body"></tbody>
      </table>
    </div>
  </div>

  <!-- DAILY FOCUS FORM -->
  <div class="panel" id="panel-form">
    <div class="form-topbar">
      <button class="back-btn" id="btn-back-top">← Back to Schedule</button>
      <h2>Daily Focus Form</h2>
    </div>
    <div class="daily-form">
